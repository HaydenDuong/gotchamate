# ── LLM ──────────────────────────────────────────────────────────────────────
# Option 1: OpenAI (paid, reliable)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Option 2: Google Gemini (free tier available)
# GEMINI_API_KEY=your-gemini-key-here
# Valid models: gemini-2.5-flash, gemini-2.5-pro, gemini-3.1-pro-preview, etc.
# GEMINI_MODEL=gemini-2.5-flash

# ── Web app ───────────────────────────────────────────────────────────────────
# Demo login credentials (single shared user for hackathon)
# DEMO_USER=demo
# DEMO_PASSWORD=demo123

# Session cookie signing key — change to any long random string
# SECRET_KEY=change-me-to-a-long-random-string
